{
  "$comment": "Ejemplo de configuración MCP para MV Data Governance. Copiá este archivo como .mcp.json y activá solo los servers que uses. NUNCA pongas tokens reales acá: usá variables de entorno.",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}" }
    },
    "$optional_filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    }
  }
}
