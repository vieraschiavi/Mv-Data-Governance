{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(pip install:*)",
      "Bash(python -m pytest:*)",
      "Bash(pytest:*)",
      "Bash(python -m bi_api.main:*)",
      "Bash(python -m mvdg.server:*)",
      "Bash(python assets/video/build_video.py:*)",
      "Bash(streamlit run:*)",
      "Bash(python -m http.server:*)",
      "Bash(python -c:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Read(*)",
      "Grep(*)",
      "Glob(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(.streamlit/secrets.toml)",
      "Read(**/*.pem)",
      "Read(**/id_rsa*)",
      "Read(**/*.key)",
      "Read(landing/payments-config.js)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start.sh" }
        ]
      }
    ]
  }
}
